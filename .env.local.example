# 행사별 Google Apps Script Web App URL. 배포 방법은 google-apps-script/README.md 참고.
# 새 행사를 추가할 때마다 NEXT_PUBLIC_GAS_WEB_APP_URL_<행사슬러그> 형태로 변수를 추가하고,
# 해당 행사의 config/events/<행사>.ts 의 gasWebAppUrl에서 참조하세요.
# 실제 값은 이 파일이 아닌 .env.local에 넣으세요 (.env.local은 git에 커밋되지 않습니다).
NEXT_PUBLIC_GAS_WEB_APP_URL_SAMSUNG_EXECUTIVE_DINNER=YOUR_GAS_WEB_APP_URL_HERE

# 실제 배포 도메인 (OG 이미지 등 절대 URL 계산에 사용). 미설정 시 http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://YOUR_DOMAIN_HERE
